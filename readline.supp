{
    Ignore_Readline_Leaks
    Memcheck:Leak
    match-leak-kinds: reachable,definite,indirect,possible
    ...
    obj:*/libreadline.so*
}
{
    Ignore_Add_History_Leaks
    Memcheck:Leak
    match-leak-kinds: reachable,definite,indirect,possible
    ...
    fun:add_history
}
{
    Ignore_LibHistory_Leaks
    Memcheck:Leak
    ...
    obj:*/libhistory.so*
}
